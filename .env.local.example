# Copia a .env.local (no lo subas a Git).

NEXT_PUBLIC_DEMO_MODE=false

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Producción (Vercel): usa GEMINI_API_KEY — no se expone al navegador.
# Local: puedes usar GEMINI_API_KEY o seguir con NEXT_PUBLIC_GEMINI_API_KEY.
GEMINI_API_KEY=
# NEXT_PUBLIC_GEMINI_API_KEY=

# Opcional: modelo Gemini (por defecto gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Recomendado en producción (PDF/storage/admin APIs)
SUPABASE_SERVICE_ROLE_KEY=

# Google Drive API (cuenta de servicio, solo lectura)
# 1) Crea claves JSON en Google Cloud → comparte la carpeta de normativa con el client_email del JSON.
# 2) Pega aquí la private_key del JSON (entre comillas; los saltos de línea como \n).
# GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=api-a-drive@steady-observer-481514-h0.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY=
# Carpeta por defecto (opcional; si no, usa la carpeta legal del proyecto)
# GOOGLE_DRIVE_NORMATIVA_FOLDER_ID=
